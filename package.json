{
  "name": "@sndrgrdn/opencode-autoresearch",
  "version": "0.1.1",
  "description": "Autonomous experiment loop plugin for OpenCode - optimize code through iterative experimentation",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "skills/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "smoke": "bun run build && bun run smoke.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.26",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "opencode",
    "plugin",
    "autoresearch",
    "optimization",
    "experiment"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sndrgrdn/opencode-autoresearch.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
